{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Hyde Agent",
  "version": "0.1.0",
  "identifier": "com.hydeagent.app",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "overlay",
        "title": "Hyde Agent",
        "url": "overlay/index.html",
        "width": 800,
        "height": 650,
        "transparent": false,
        "decorations": true,
        "visible": true,
        "alwaysOnTop": false,
        "center": true,
        "resizable": true,
        "skipTaskbar": false
      },
      {
        "label": "settings",
        "title": "Hyde Agent Settings",
        "url": "settings/settings.html",
        "width": 800,
        "height": 600,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
